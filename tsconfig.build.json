{
    "extends": "./tsconfig.app.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "rootDir": "src",
        "allowImportingTsExtensions": false
    },
    "include": [
        "src/index.ts",
        "src/**/*.ts",
        "src/**/*.tsx"
    ],
    "exclude": [
        "src/App.tsx",
        "src/main.tsx",
        "src/vite-env.d.ts",
        "**/*.test.ts",
        "**/*.test.tsx"
    ]
}